---
import Layout from '../layouts/Layout.astro';
import NavBar from '../components/NavBar.jsx';
import EventsGrid from '../components/EventsGrid.jsx';
---

<Layout title="Eventos — LaJarana" description="Encuentra los mejores eventos y compra tus entradas digitales.">
  <NavBar current="eventos" client:load />

  <section class="eventos-page">
    <div class="container">
      <h1 class="section-title" data-aos="fade-up">Todos los <span class="gradient-text">eventos</span></h1>
      <p class="section-subtitle" data-aos="fade-up" data-aos-delay="100">Encuentra tu próximo evento favorito y consigue tus entradas.</p>
      <EventsGrid client:load />
    </div>
  </section>

  <!-- ORG CTA -->
  <section style="padding:60px 0;text-align:center;">
    <div class="container">
      <h3 style="font-size:1.4rem;margin-bottom:8px;">¿Organizas eventos?</h3>
      <p style="color:var(--white-60);margin-bottom:20px;max-width:500px;margin-left:auto;margin-right:auto;">Publica tu evento y vende entradas sin comisiones</p>
      <a href="https://lajarana-org.luminari.agency" class="btn-primary" style="display:inline-flex;">Crear mi evento →</a>
    </div>
  </section>

  <footer class="footer">
    <div class="container" style="text-align:center;">
      <hr class="gradient-separator" style="margin-bottom:24px;" />
      <p style="color:var(--white-60);font-size:0.85rem;margin-bottom:8px;">© 2026 LaJarana. Hecho con 💜 por <a href="https://luminari.agency" style="color:var(--violet);text-decoration:none;">Luminari Agency</a></p>
      <p style="color:var(--white-60);font-size:0.8rem;"><a href="/terminos" style="color:var(--violet);text-decoration:none;">Términos y Condiciones</a> · <a href="/privacidad" style="color:var(--violet);text-decoration:none;">Política de Privacidad</a></p>
    </div>
  </footer>
</Layout>

<style>
  .eventos-page {
    padding: 140px 0 80px;
    min-height: 80vh;
  }
  :global(.events-search-bar) {
    margin-bottom: 32px;
  }
  :global(.events-search-input) {
    max-width: 500px;
    border-radius: 50px !important;
    padding: 14px 24px !important;
  }
  .footer {
    padding: 32px 0;
  }
</style>
