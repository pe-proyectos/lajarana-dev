---
import Layout from '../layouts/Layout.astro';
import NavBar from '../components/NavBar.jsx';
import HeroSearch from '../components/HeroSearch.jsx';
import FeaturedEvents from '../components/FeaturedEvents.jsx';
import EventMarquee from '../components/EventMarquee.jsx';
---

<Layout title="LaJarana — Encuentra eventos y compra entradas" description="Encuentra los mejores eventos en Perú. Compra entradas digitales, muestra tu QR y disfruta." ogImage="/og-image.jpg" jsonLd={JSON.stringify({"@context":"https://schema.org","@type":"Organization","name":"LaJarana","url":"https://dev-lajarana.luminari.agency","description":"Plataforma de boletería digital para eventos en Perú"})}>
  <NavBar current="home" client:load />

  <!-- HERO WITH SEARCH -->
  <section class="hero-search">
    <HeroSearch client:load />
  </section>

  <!-- MARQUEE -->
  <EventMarquee client:load />

  <!-- EVENTS GRID -->
  <section id="eventos" class="section--events">
    <div class="container">
      <h2 class="section-title">Próximos <span class="gradient-text">eventos</span></h2>
      <FeaturedEvents client:load />
      <div class="section-cta">
        <a href="/eventos" class="btn-secondary">Ver todos los eventos →</a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container footer-inner-minimal">
      <div class="footer-brand">
        <div class="logo"><img src="/logo.png" alt="LaJarana" style="height:48px;margin-right:8px;vertical-align:middle;" /> LaJarana</div>
      </div>
      <nav class="footer-nav">
        <a href="/eventos">Eventos</a>
        <a href="/mi-cuenta">Mi Cuenta</a>
        <a href="/terminos">Términos y Condiciones</a>
        <a href="/privacidad">Política de Privacidad</a>
        <a href="https://lajarana-org.luminari.agency" class="footer-org-link">¿Organizas eventos? Crea el tuyo →</a>
      </nav>
      <div class="footer-copy">
        <p>© 2026 LaJarana · <a href="https://luminari.agency" class="luminari-link">Luminari Agency</a></p>
      </div>
    </div>
  </footer>
</Layout>

<style>
  /* HERO SEARCH */
  .hero-search {
    padding: 140px 0 60px;
    position: relative;
    text-align: center;
    overflow: hidden;
    min-height: 50vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  :global(.hero-search-content) {
    position: relative;
    z-index: 1;
    max-width: 720px;
    margin: 0 auto;
    padding: 0 24px;
    width: 100%;
  }

  :global(.hero-search-title) {
    font-size: clamp(2rem, 6vw, 3.5rem);
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 32px;
  }

  :global(.hero-search-form) {
    margin-bottom: 24px;
  }

  :global(.hero-search-bar) {
    display: flex;
    align-items: center;
    background: var(--white-06);
    border: 1px solid var(--white-10);
    border-radius: 56px;
    padding: 6px 6px 6px 20px;
    transition: border-color 0.2s, box-shadow 0.2s;
    max-width: 600px;
    margin: 0 auto;
  }

  :global(.hero-search-bar:focus-within) {
    border-color: var(--violet);
    box-shadow: 0 0 24px var(--violet-20, rgba(139, 92, 246, 0.2));
  }

  :global(.hero-search-icon) {
    font-size: 1.2rem;
    margin-right: 12px;
    flex-shrink: 0;
  }

  :global(.hero-search-input) {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    color: var(--white);
    font-size: 1.05rem;
    padding: 12px 0;
    min-width: 0;
  }

  :global(.hero-search-input::placeholder) {
    color: var(--white-40, rgba(255,255,255,0.4));
  }

  :global(.hero-search-btn) {
    background: var(--violet);
    color: var(--white);
    border: none;
    border-radius: 50px;
    padding: 12px 28px;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s;
    flex-shrink: 0;
  }

  :global(.hero-search-btn:hover) {
    background: var(--violet-light, #9b7af7);
    transform: scale(1.03);
  }

  /* CATEGORY PILLS */
  :global(.hero-categories) {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
  }

  :global(.hero-category-pill) {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 8px 18px;
    font-size: 0.85rem;
    color: var(--white-80, rgba(255,255,255,0.8));
    background: var(--white-06);
    border: 1px solid var(--white-10);
    border-radius: 50px;
    text-decoration: none;
    transition: background 0.2s, border-color 0.2s, color 0.2s;
  }

  :global(.hero-category-pill:hover) {
    background: var(--white-10);
    border-color: var(--white-20, rgba(255,255,255,0.2));
    color: var(--white);
  }

  /* EVENTS SECTION */
  .section--events {
    overflow: hidden;
    padding-bottom: 80px;
  }

  .section-cta {
    text-align: center;
    margin-top: 48px;
  }

  /* FOOTER MINIMAL */
  .footer {
    padding: 48px 0 32px;
    border-top: 1px solid var(--white-06);
  }

  .footer-inner-minimal {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    text-align: center;
  }

  .footer-nav {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .footer-nav a {
    color: var(--white-60);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s;
  }

  .footer-nav a:hover { color: var(--white); }

  .footer-org-link {
    color: var(--violet) !important;
    font-weight: 500;
  }

  .footer-org-link:hover {
    color: var(--white) !important;
  }

  .footer-copy {
    color: var(--white-40, rgba(255,255,255,0.4));
    font-size: 0.8rem;
  }

  .footer-copy a {
    color: var(--violet);
    text-decoration: none;
  }

  /* NAV STYLES (keep) */
  :global(.nav) {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    padding: 16px 0;
    background: rgba(10,10,10,0.8);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--white-06);
  }
  :global(.nav-inner) { display: flex; align-items: center; justify-content: space-between; }
  :global(.logo) { font-size: 1.4rem; font-weight: 700; text-decoration: none; color: var(--white); }
  :global(.nav-links) { display: flex; align-items: center; gap: 32px; }
  :global(.nav-links a) { color: var(--white-60); text-decoration: none; font-size: 0.95rem; transition: color 0.2s; }
  :global(.nav-links a:hover), :global(.nav-links a.nav-active) { color: var(--white); }
  :global(.nav-mobile-toggle) { display: none; background: none; border: none; cursor: pointer; padding: 8px; }
  :global(.hamburger) { display: flex; flex-direction: column; gap: 5px; width: 24px; }
  :global(.hamburger span) { display: block; height: 2px; background: var(--white); border-radius: 2px; transition: transform 0.3s, opacity 0.3s; }
  :global(.hamburger--open span:nth-child(1)) { transform: rotate(45deg) translate(5px, 5px); }
  :global(.hamburger--open span:nth-child(2)) { opacity: 0; }
  :global(.hamburger--open span:nth-child(3)) { transform: rotate(-45deg) translate(5px, -5px); }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    :global(.nav-mobile-toggle) { display: block; }
    :global(.nav-links) {
      display: none; position: absolute; top: 100%; left: 0; right: 0;
      background: rgba(10,10,10,0.95); backdrop-filter: blur(16px);
      flex-direction: column; padding: 24px; gap: 16px;
      border-bottom: 1px solid var(--white-06);
    }
    :global(.nav-links--open) { display: flex; }
    .hero-search { padding: 120px 0 40px; min-height: auto; }
    :global(.hero-search-btn) { padding: 10px 20px; font-size: 0.9rem; }
  }
</style>
